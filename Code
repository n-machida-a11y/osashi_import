// 直送先マスタから取得する列（キー: 受注データの列名、値: マスタの列番号(1始まり)）
const MASTER_COLS_JIKASO = {
  '直送先名':       2,
  '直送先名２':     3,
  '郵便番号':       8,
  '住所１':         9,
